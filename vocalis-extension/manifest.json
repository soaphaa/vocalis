{
  "manifest_version": 3,
  "name": "Vocalis",
  "version": "3.0.0",
  "description": "Live captions and transcription for accessibility",

  "permissions": [
    "activeTab",
    "scripting",
    "tabs",
    "storage"
  ],

  "action": {
    "default_popup": "popup.html",
    "default_title": "Vocalis Live Captions"
  },

  "background": {
    "service_worker": "background.js"
  },

  "icons": {
    "16": "images/icon-16.png",
    "48": "images/icon-48.png",
    "128": "images/icon-128.png"
  },

  "content_scripts": [
    {
      "matches": [
        "https://meet.google.com/*",
        "https://www.zoom.us/*",
        "https://teams.microsoft.com/*",
        "https://docs.google.com/*",
        "https://slides.google.com/*",
        "https://*.webex.com/*",
        "*://localhost/*",
        "file://*/*"
      ],
      "js": ["app.js", "content.js"]
    }
  ]
}